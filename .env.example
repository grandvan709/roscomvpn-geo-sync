# =====================================
# roscomvpn-geo-sync configuration
# =====================================

# Расписание cron (UTC по умолчанию). Скрипт запускается дважды в сутки.
CRON_SCHEDULE=0 */12 * * *
TZ=UTC

# === Geo-файлы (обязательно) ===
GEOIP_REPO=hydraponique/roscomvpn-geoip
GEOSITE_REPO=hydraponique/roscomvpn-geosite
# Минимальный размер файла (защита от обрезанных загрузок). Magic-byte валидация
# дополнительно проверяет protobuf-формат.
GEOIP_MIN_SIZE=10000
GEOSITE_MIN_SIZE=10000

# === Routing JSON (обязательно) ===
# Откуда тянуть JSONSUB.JSON для INCY и Happ.
ROUTING_REPO=hydraponique/roscomvpn-routing
ROUTING_BRANCH=main
# Клиенты, для которых строить deeplinks. Поддерживается: INCY, HAPP.
# Если оставить только один — второй пропустится.
ROUTING_CLIENTS=INCY,HAPP

# =====================================
# rsync на удалённый сервер раздачи (опционально)
# =====================================
# Если RSYNC_HOST не задан — rsync пропускается, файлы только в локальный кэш ./files/
# Целевой сервер должен принимать SSH-ключ (см. README — rrsync для безопасности).
RSYNC_HOST=
RSYNC_USER=
RSYNC_PORT=22
# Для rrsync-restricted цели используйте относительный путь ./
RSYNC_REMOTE_DEST=./
# Внутри контейнера путь не менять. Маунт делается через docker-compose.
SSH_KEY_PATH=/app/ssh-key

# Публичный URL раздачи geo-файлов. Если задан:
# - подставляется в JSONSUB как Geoipurl/Geositeurl
# - после rsync выполняется health-check этих URL'ов
# Если НЕ задан — в JSONSUB остаются оригинальные URL'ы (cdn.jsdelivr.net).
GEO_PUBLIC_URL=

# =====================================
# Push deeplinks в Remnawave-панель (опционально)
# =====================================
# Если REMNAWAVE_API_URL и REMNAWAVE_API_TOKEN не заданы оба — push пропускается,
# deeplinks выводятся только в логах (для ручного копирования в панель).
REMNAWAVE_API_URL=
# Bearer JWT. Создайте отдельный API-токен в Caddy auth-portal с ролью ADMIN/API.
REMNAWAVE_API_TOKEN=
# Опциональный X-Api-Key (если у вашей панели Caddy auth-portal требует его).
REMNAWAVE_CADDY_TOKEN=
# Имя правила в Response Rules, которое содержит INCY-deeplink (header key=routing).
INCY_RULE_NAME=INCY Routing

# =====================================
# Telegram-уведомления (опционально)
# =====================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Опционально: ID треда (для групп с топиками).
TELEGRAM_THREAD_ID=
